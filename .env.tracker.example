# Optional overrides for apps/tracker.
# Copy to .env.tracker when tracker needs its own runtime values.

TOKEN_STORAGE_PATH=data/.spotify-tokens.tracker.json
DATABASE_URL=file:./dev.db

POLL_INTERVAL_MS=2500
PRINT_ON_START=true
BACKFILL_INTERVAL_MS=60000
BACKFILL_LIMIT=50

SAVED_TRACKS_ENABLED=true
SAVED_TRACKS_SYNC_INTERVAL_MS=120000

BACKUP_ENABLED=false
S3_ENDPOINT=https://s3.timeweb.cloud
S3_BUCKET=backups
S3_PREFIX=backups
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_RESTORE_ON_EMPTY_DB=true
BACKUP_CRON=0 0 * * *
BACKUP_RETENTION_DAYS=14
