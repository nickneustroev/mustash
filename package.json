{
  "name": "spotify-track-console-notifier",
  "description": "Local CLI app that prints current Spotify track on change",
  "version": "1.0.0",
  "license": "ISC",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:tracker",
    "dev:tracker": "tsx watch --tsconfig apps/tracker/tsconfig.json apps/tracker/src/core/main.ts",
    "dev:auto-playlists": "tsx watch --tsconfig apps/auto-playlists/tsconfig.json apps/auto-playlists/src/core/main.ts",
    "build": "npm run build:tracker && npm run build:auto-playlists",
    "build:tracker": "tsc -p apps/tracker/tsconfig.json",
    "build:auto-playlists": "tsc -p apps/auto-playlists/tsconfig.json",
    "start": "npm run start:tracker",
    "start:tracker": "node apps/tracker/dist/core/main.js",
    "start:auto-playlists": "node apps/auto-playlists/dist/core/main.js",
    "start:docker": "prisma migrate deploy && node apps/tracker/dist/core/main.js",
    "test": "npm run test:tracker && npm run test:auto-playlists",
    "test:tracker": "vitest run --config apps/tracker/vitest.config.ts",
    "test:auto-playlists": "vitest run --config apps/auto-playlists/vitest.config.ts",
    "test:watch": "npm run test:watch:tracker",
    "test:watch:tracker": "vitest --config apps/tracker/vitest.config.ts",
    "test:watch:auto-playlists": "vitest --config apps/auto-playlists/vitest.config.ts",
    "lint": "eslint . --config apps/tracker/eslint.config.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio --port 5555",
    "backup": "tsx apps/tracker/src/backup/backup-s3.ts"
  },
  "dependencies": {
    "@spotify-helper/spotify": "workspace:*",
    "@aws-sdk/client-s3": "^3.744.0",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@prisma/adapter-better-sqlite3": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "undici": "^7.24.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "prisma": "^7.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
