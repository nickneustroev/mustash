{
  "name": "spotify-track-console-notifier",
  "description": "Local CLI app that prints current Spotify track on change",
  "version": "1.0.0",
  "license": "ISC",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:auto-playlists",
    "dev:auto-playlists": "tsx watch --tsconfig apps/auto-playlists/tsconfig.json apps/auto-playlists/src/core/main.ts",
    "build": "npm run build:auto-playlists",
    "build:auto-playlists": "tsc -p apps/auto-playlists/tsconfig.json",
    "start": "npm run start:auto-playlists",
    "start:auto-playlists": "node apps/auto-playlists/dist/core/main.js",
    "start:docker": "npm run start:docker:auto-playlists",
    "start:docker:auto-playlists": "prisma migrate deploy && node apps/auto-playlists/dist/core/main.js",
    "test": "npm run test:auto-playlists",
    "test:auto-playlists": "vitest run --config apps/auto-playlists/vitest.config.ts",
    "test:watch": "npm run test:watch:auto-playlists",
    "test:watch:auto-playlists": "vitest --config apps/auto-playlists/vitest.config.ts",
    "lint": "eslint .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:studio": "prisma studio --port 5555"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@spotify-helper/db": "workspace:*",
    "@spotify-helper/spotify": "workspace:*",
    "dotenv": "^17.2.3",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sharp": "^0.34.5",
    "undici": "^7.24.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "prisma": "^7.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
